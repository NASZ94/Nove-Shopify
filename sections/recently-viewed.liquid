<section class="recently-viewed">

    <div class="page-width">

        <div class="section-header">

            <h2 class="section-title">

                Recently Viewed

            </h2>

            <p class="section-subtitle">

                Products you've looked at recently.

            </p>

        </div>

        <div
            id="RecentlyViewedProducts"
            class="product-grid"
        >

            <div class="recently-viewed-empty">

                <p>

                    Browse products to build your recently viewed list.

                </p>

            </div>

        </div>

    </div>

</section>

