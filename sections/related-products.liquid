<section class="products related-products">

  <div class="container">

    <h2 class="section-title">

      You May Also Like

    </h2>

    {% assign related_collection = product.collections.first %}

    {% if related_collection != blank %}

      <div class="product-grid">

        {% assign shown = 0 %}

        {% for related_product in related_collection.products %}

          {% if related_product.id != product.id and shown < 4 %}

            <article class="product-card">

              <button
                class="wishlist-button"
                data-product-handle="{{ related_product.handle }}"
                aria-label="Add to wishlist"
                aria-pressed="false"
                type="button">

                ♡

              </button>

              <a href="{{ related_product.url }}">

                {% if related_product.compare_at_price > related_product.price %}

                  <span class="badge">
                    Sale
                  </span>

                {% endif %}

                {% if related_product.featured_image %}

                  {{
                    related_product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      alt: related_product.title
                  }}

                {% endif %}

                <div class="rating">
                  ★★★★★
                </div>

                <h3>

                  {{ related_product.title }}

                </h3>

              </a>

              <div class="price">

                {{ related_product.price | money }}

              </div>

              {% if related_product.compare_at_price > related_product.price %}

                <div class="compare-price">

                  {{ related_product.compare_at_price | money }}

                </div>

              {% endif %}

              <a
                href="{{ related_product.url }}"
                class="btn">

                View Product

              </a>

            </article>

            {% assign shown = shown | plus: 1 %}

          {% endif %}

        {% endfor %}

      </div>

    {% endif %}

  </div>

</section>

{% schema %}
{
  "name": "Related Products",
  "settings": [],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}