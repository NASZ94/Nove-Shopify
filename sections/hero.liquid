<section class="hero">

  <div class="container hero-grid">

    <div class="hero-content">

      <span class="eyebrow">
        {{ section.settings.eyebrow }}
      </span>

      <h1>
        {{ section.settings.heading }}
      </h1>

      <p>
        {{ section.settings.text }}
      </p>

      <div class="hero-buttons">

        <a href="{{ section.settings.button_link }}" class="btn">
          {{ section.settings.button_label }}
        </a>

        <a href="/collections/all" class="btn btn-secondary">
          Explore
        </a>

      </div>

    </div>

    <div class="hero-image">

      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 900 | image_tag }}
      {% else %}
        <img src="https://placehold.co/700x800" alt="Beauty Collection">
      {% endif %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "NEW COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty, Naturally."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover skincare, makeup, and beauty essentials designed for every routine."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}