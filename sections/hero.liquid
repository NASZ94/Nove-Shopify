<section class="hero">

  <div class="container hero-grid">

    <div class="hero-content">

      {% if section.settings.eyebrow != blank %}
        <span class="eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <p>{{ section.settings.text }}</p>
      {% endif %}

      <div class="hero-buttons">

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
            class="btn"
          >
            {{ section.settings.button_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_button_label != blank %}
          <a
            href="{{ routes.all_products_collection_url }}"
            class="btn btn-secondary"
          >
            {{ section.settings.secondary_button_label }}
          </a>
        {% endif %}

      </div>

    </div>

    <div class="hero-media">

      {% if section.settings.video != blank %}

        {{
          section.settings.video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            playsinline: true,
            preload: 'metadata',
            class: 'hero-video'
        }}

      {% elsif section.settings.image != blank %}

        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'hero-image-element',
            loading: 'eager',
            widths: '450,700,900,1200',
            alt: section.settings.heading
        }}

      {% else %}

        {{
          'hero-apparel-1'
          | placeholder_svg_tag: 'placeholder-svg hero-placeholder'
        }}

      {% endif %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "NEW COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty, Naturally."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Discover skincare, makeup, and beauty essentials designed for every routine."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "Explore"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Hero Video"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}