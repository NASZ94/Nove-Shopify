<footer class="footer">

  <div class="container">

    <div class="footer-grid">

      <div class="footer-brand">

        <h2>NOVE</h2>

        <p>
          Beauty, Naturally.
        </p>

        <p>
          Premium skincare, makeup, haircare, and fragrance curated for everyday beauty.
        </p>

      </div>

      <div class="footer-links">

        <h4>Shop</h4>

        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/makeup">Makeup</a></li>
          <li><a href="/collections/skincare">Skincare</a></li>
          <li><a href="/collections/hair">Hair</a></li>
          <li><a href="/collections/fragrance">Fragrance</a></li>
        </ul>

      </div>

      <div class="footer-links">

        <h4>Customer Care</h4>

        <ul>
          <li><a href="#">Shipping</a></li>
          <li><a href="#">Returns</a></li>
          <li><a href="#">Contact</a></li>
          <li><a href="#">FAQs</a></li>
        </ul>

      </div>

      <div class="footer-newsletter">

        <h4>Join the Nove Community</h4>

        <p>
          Subscribe to receive new arrivals, exclusive offers, and beauty tips.
        </p>

        <form>

          <input
            type="email"
            placeholder="Email address"
          >

          <button class="btn">
            Subscribe
          </button>

        </form>

      </div>

    </div>

    <div class="footer-bottom">

      <p>
        © {{ 'now' | date: "%Y" }} NOVE. All rights reserved.
      </p>

    </div>

  </div>

</footer>

