<footer class="footer">

  <div class="container">

    <div class="footer-grid">

      <div class="footer-brand">

        {% if section.settings.logo != blank %}
          {{
            section.settings.logo
            | image_url: width: 180
            | image_tag:
              class: 'footer-logo',
              loading: 'lazy',
              alt: shop.name
          }}
        {% else %}
          <h2>{{ shop.name }}</h2>
        {% endif %}

        {% if section.settings.tagline != blank %}
          <p>{{ section.settings.tagline }}</p>
        {% endif %}

        {% if section.settings.description != blank %}
          <p>{{ section.settings.description }}</p>
        {% endif %}

      </div>

      <div class="footer-links">

        <h4>{{ section.settings.shop_heading }}</h4>

        {% if linklists[section.settings.shop_menu] != blank %}
          <ul>
            {% for link in linklists[section.settings.shop_menu].links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      </div>

      <div class="footer-links">

        <h4>{{ section.settings.customer_heading }}</h4>

        {% if linklists[section.settings.customer_menu] != blank %}
          <ul>
            {% for link in linklists[section.settings.customer_menu].links %}
              <li>
                <a href="{{ link.url }}">{{ link.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      </div>

      <div class="footer-newsletter">

        <h4>{{ section.settings.newsletter_heading }}</h4>

        <p>{{ section.settings.newsletter_text }}</p>

        {% form 'customer' %}

          <input
            type="hidden"
            name="contact[tags]"
            value="newsletter"
          >

          <input
            type="email"
            name="contact[email]"
            placeholder="Email address"
            required
          >

          <button
            type="submit"
            class="btn"
          >
            Subscribe
          </button>

        {% endform %}

      </div>

    </div>

    <div class="footer-bottom">

      <p>
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>

    </div>

  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Beauty, Naturally."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Premium skincare, makeup, haircare, and fragrance curated for everyday beauty."
    },
    {
      "type": "text",
      "id": "shop_heading",
      "label": "Shop heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "text",
      "id": "customer_heading",
      "label": "Customer Care heading",
      "default": "Customer Care"
    },
    {
      "type": "link_list",
      "id": "customer_menu",
      "label": "Customer Care menu"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join the NOVE Community"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Subscribe to receive new arrivals, exclusive offers, and beauty tips."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}