<section class="products">

  <div class="container">

    <h2 class="section-title">
      {{ section.settings.heading }}
    </h2>

    <div class="product-grid">

      {% if section.settings.collection %}

        {% for product in section.settings.collection.products limit: 8 %}

          <!-- Replace the old product card with this one -->

          <div class="product-card">

            <span class="badge">
              Bestseller
            </span>

            <a href="{{ product.url }}">

              {{
                product.featured_image
                | image_url: width: 700
                | image_tag: loading: 'lazy'
              }}

            </a>

            <div class="rating">
              ★★★★★
            </div>

            <h3>{{ product.title }}</h3>

            <p class="price">
              {{ product.price | money }}
            </p>

            <a class="btn" href="{{ product.url }}">
              Shop Now
            </a>

          </div>

        {% endfor %}

      {% else %}

        <p>Select a collection in the Theme Editor.</p>

      {% endif %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}